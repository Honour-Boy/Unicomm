# dependencies
node_modules

# env files — never commit real values (examples are kept)
.env
.env.*
!.env.example

# Firebase Admin service-account credentials — NEVER commit
backend/config/unicomm.json
**/*firebase-adminsdk*.json
**/serviceAccount*.json

# Claude Code — keep project skills/agents/commands; ignore only local-only bits
.claude/settings.local.json
.claude/worktrees/

# Python bytecode (e.g. from skill scripts)
__pycache__/
*.pyc

# build output
dist
build

# logs / OS cruft
*.log
.DS_Store
Thumbs.db
