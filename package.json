{
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:backend": "jest --selectProjects backend",
    "test:frontend": "jest --selectProjects frontend",
    "build:frontend": "npm run build --prefix frontend",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:hosting": "npm run build:frontend && firebase deploy --only hosting",
    "deploy": "npm run build:frontend && firebase deploy --only hosting,firestore:rules,firestore:indexes"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
