# Frontend (Vite) environment variables
# Copy to `.env.local` (gitignored). Vite only exposes VITE_-prefixed vars to the client,
# and they are read via `import.meta.env`.

# Firebase Web API key — the only Firebase value currently read from env.
# The rest of firebaseConfig is hardcoded in src/components/Firebase/firebase.js.
VITE_API_KEY=

# Backend (Express) base URL. No longer used by the client (auth is session-only
# and the backend only serves /api/health) — kept for optional future API calls.
# Local: http://localhost:8001  •  Prod: your Render URL, e.g. https://unicomm-backend.onrender.com
VITE_API_URL=http://localhost:8001

# LibreTranslate endpoint (per-message translation). Optional — the app defaults
# to the self-hosted instance baked into services/messages.js. Set this to point
# at a different instance. Must be HTTPS (the app is served over HTTPS).
# VITE_TRANSLATE_URL=https://my-gpt-translator.hf.space/translate

# --- Recommended (not yet wired up) ---
# Externalize the rest of the Firebase web config instead of hardcoding it:
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
#
# Translation API key, if/when the translation provider requires one
# VITE_TRANSLATION_API_KEY=
