# Backend environment variables
# Copy to `.env` (gitignored). Loaded via dotenv in server.js.

# Server port (defaults to 8001 if unset)
PORT=8001

# --- Recommended (not yet wired up) ---
# CORS origin is currently hardcoded to http://localhost:5173 in server.js.
# Move it here to make it configurable per environment:
# FRONTEND_ORIGIN=http://localhost:5173
#
# Firebase Admin credentials are currently loaded from backend/config/unicomm.json
# (a committed service-account key — see handoff.md "Next Steps"). Prefer storing the
# JSON as a single-line env var and parsing it, so no secret lives in the repo:
# FIREBASE_SERVICE_ACCOUNT=
